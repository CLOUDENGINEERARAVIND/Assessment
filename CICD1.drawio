        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart LR\n  Dev([Developer]) --&gt;|push / open PR| GH[\&quot;GitHub&lt;br/&gt;source repo\&quot;]\n  GH --&gt; GA[\&quot;GitHub Actions&lt;br/&gt;workflow triggered\&quot;]\n  GA --&gt; SEC\n\n  subgraph SEC [\&quot;PRE-MERGE SECURITY GATES — run on every PR\&quot;]\n    direction TB\n    SECRET[\&quot;Secret scanning&lt;br/&gt;Gitleaks / TruffleHog\&quot;]\n    SAST[\&quot;SAST + Quality Gate&lt;br/&gt;SonarQube\&quot;]\n    SCA[\&quot;Dependency scan / SCA&lt;br/&gt;Snyk · Dependabot\&quot;]\n    IAC[\&quot;IaC scan&lt;br/&gt;Checkov · tfsec · KICS\&quot;]\n    SECRET --&gt; SAST --&gt; SCA --&gt; IAC\n  end\n\n  SEC --&gt;|quality gate PASS → merge to main| SPLIT(( ))\n  SPLIT --&gt; FE\n  SPLIT --&gt; BE\n\n  subgraph FE [\&quot;FRONTEND PIPELINE — React SPA\&quot;]\n    direction TB\n    FBUILD[\&quot;Actions runner&lt;br/&gt;npm ci · lint · unit tests&lt;br/&gt;build static bundle\&quot;]\n    FBUILD --&gt; FSON[\&quot;SonarQube&lt;br/&gt;coverage + quality\&quot;]\n    FSON --&gt; FDEP[\&quot;Deploy: S3 sync +&lt;br/&gt;CloudFront invalidation\&quot;]\n  end\n\n  subgraph BE [\&quot;BACKEND PIPELINE — Python API → EKS\&quot;]\n    direction TB\n    BBUILD[\&quot;Actions runner&lt;br/&gt;pytest · docker build\&quot;]\n    BBUILD --&gt; BTRIVY[\&quot;Image scan&lt;br/&gt;Trivy (CVE · secrets · misconfig)\&quot;]\n    BTRIVY --&gt; BSIGN[\&quot;Sign image&lt;br/&gt;Cosign / Sigstore\&quot;]\n    BSIGN --&gt; BPUSH[\&quot;Push → Amazon ECR&lt;br/&gt;(tag = git SHA)\&quot;]\n  end\n\n  FDEP --&gt; DEPLOY\n  BPUSH --&gt; DEPLOY\n\n  subgraph DEPLOY [\&quot;DEPLOY TO EKS — multi-region Blue/Green\&quot;]\n    direction TB\n    ARGO[\&quot;Helm / ArgoCD GitOps&lt;br/&gt;deploy to GREEN cluster (us-west-2)\&quot;]\n    ARGO --&gt; OPA[\&quot;Admission policy gate&lt;br/&gt;OPA Gatekeeper / Kyverno\&quot;]\n    OPA --&gt; DAST[\&quot;DAST&lt;br/&gt;OWASP ZAP vs GREEN\&quot;]\n    DAST --&gt; ITEST[\&quot;Integration + smoke tests&lt;br/&gt;on GREEN ingress\&quot;]\n  end\n\n  ITEST --&gt; APPROVE{\&quot;Manual approval&lt;br/&gt;production gate\&quot;}\n  APPROVE --&gt;|approved| SWITCH[\&quot;Route 53 weighted switch&lt;br/&gt;BLUE → GREEN via ingress controller\&quot;]\n  APPROVE --&gt;|reject / tests fail| HOLD[\&quot;Hold on BLUE&lt;br/&gt;no traffic shift\&quot;]\n  SWITCH --&gt; LIVE[\&quot;GREEN is now PRODUCTION\&quot;]\n  LIVE --&gt; MON[\&quot;Observability&lt;br/&gt;CloudWatch · Prometheus · X-Ray\&quot;]\n  MON -.-&gt;|SLO breach / alarm| ROLL[\&quot;Auto rollback&lt;br/&gt;Route 53 revert → BLUE\&quot;]\n\n  SAST -.-&gt; DD[\&quot;Findings aggregated&lt;br/&gt;DefectDojo + Security Hub\&quot;]\n  BTRIVY -.-&gt; DD\n  DAST -.-&gt; DD\n\n  classDef src fill:#E1F0FF,stroke:#4A90D9,color:#13314f;\n  classDef sec fill:#F8CECC,stroke:#B85450,color:#5e1f1c;\n  classDef fe fill:#D5E8D4,stroke:#82B366,color:#274d1f;\n  classDef be fill:#FCE4CC,stroke:#E8943A,color:#5c3a12;\n  classDef dep fill:#E6D9F2,stroke:#8C5BC7,color:#3c1d63;\n  classDef gate fill:#FFF2CC,stroke:#D6B656,color:#5a4a14;\n  classDef prod fill:#E0F5F1,stroke:#3CA99A,color:#11463e;\n  classDef danger fill:#F8CECC,stroke:#B85450,color:#5e1f1c;\n  class Dev,GH,GA src;\n  class SECRET,SAST,SCA,IAC,DD sec;\n  class FBUILD,FSON,FDEP fe;\n  class BBUILD,BTRIVY,BSIGN,BPUSH be;\n  class ARGO,OPA,DAST,ITEST dep;\n  class APPROVE gate;\n  class SWITCH,LIVE,MON prod;\n  class HOLD,ROLL danger;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="2">
